{
  "name": "git-simple-compare",
  "displayName": "Git Simple Compare",
  "description": "%ext.description%",
  "version": "0.1.0",
  "publisher": "newdlops",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/newdlops/gitsimplecompare.git"
  },
  "bugs": {
    "url": "https://github.com/newdlops/gitsimplecompare/issues"
  },
  "homepage": "https://github.com/newdlops/gitsimplecompare#readme",
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "diff",
    "compare",
    "branch",
    "merge"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitSimpleCompare.compareBranches",
        "title": "%cmd.compareBranches%",
        "category": "Git Simple Compare",
        "icon": "$(git-compare)"
      },
      {
        "command": "gitSimpleCompare.checkoutBranch",
        "title": "%cmd.checkoutBranch%",
        "category": "Git Simple Compare",
        "icon": "$(git-branch)"
      },
      {
        "command": "gitSimpleCompare.compareFileWithBranch",
        "title": "%cmd.compareFileWithBranch%",
        "category": "Git Simple Compare",
        "icon": "$(git-compare)"
      },
      {
        "command": "gitSimpleCompare.compareActiveFileWithBranch",
        "title": "%cmd.compareActiveFileWithBranch%",
        "category": "Git Simple Compare",
        "icon": "$(git-compare)"
      },
      {
        "command": "gitSimpleCompare.refreshChanges",
        "title": "%cmd.refreshChanges%",
        "category": "Git Simple Compare",
        "icon": "$(refresh)"
      },
      {
        "command": "gitSimpleCompare.openChangeDiff",
        "title": "%cmd.openChangeDiff%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.changeComparisonRef",
        "title": "%cmd.changeComparisonRef%",
        "category": "Git Simple Compare",
        "icon": "$(edit)"
      },
      {
        "command": "gitSimpleCompare.viewAsTree",
        "title": "%cmd.viewAsTree%",
        "category": "Git Simple Compare",
        "icon": "$(list-tree)"
      },
      {
        "command": "gitSimpleCompare.viewAsList",
        "title": "%cmd.viewAsList%",
        "category": "Git Simple Compare",
        "icon": "$(list-flat)"
      },
      {
        "command": "gitSimpleCompare.changeSortOrder",
        "title": "%cmd.changeSortOrder%",
        "category": "Git Simple Compare",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "gitSimpleCompare.toggleSection.repos.visible",
        "title": "%cmd.section.repos.checked%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.repos.hidden",
        "title": "%cmd.section.repos%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.changes.visible",
        "title": "%cmd.section.changes.checked%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.changes.hidden",
        "title": "%cmd.section.changes%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.compare.visible",
        "title": "%cmd.section.compare.checked%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.compare.hidden",
        "title": "%cmd.section.compare%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.stashes.visible",
        "title": "%cmd.section.stashes.checked%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.stashes.hidden",
        "title": "%cmd.section.stashes%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.applyLeftToRight",
        "title": "%cmd.applyLeftToRight%",
        "category": "Git Simple Compare",
        "icon": "$(arrow-right)"
      },
      {
        "command": "gitSimpleCompare.openDiffFileEditor",
        "title": "%cmd.openDiffFileEditor%",
        "category": "Git Simple Compare",
        "icon": "$(go-to-file)",
        "enablement": "gitSimpleCompare.activeExtensionDiff"
      },
      {
        "command": "gitSimpleCompare.stageSelectedLines",
        "title": "%cmd.stageSelectedLines%",
        "category": "Git Simple Compare",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "gitSimpleCompare.toggleSelectedLineCheckbox",
        "title": "%cmd.toggleSelectedLineCheckbox%",
        "category": "Git Simple Compare",
        "icon": "$(checklist)"
      },
      {
        "command": "gitSimpleCompare.chooseHunkControlMode",
        "title": "%cmd.chooseHunkControlMode%",
        "category": "Git Simple Compare",
        "icon": "$(settings-gear)"
      },
      {
        "command": "gitSimpleCompare.showGraph",
        "title": "%cmd.showGraph%",
        "category": "Git Simple Compare",
        "icon": "$(graph)"
      },
      {
        "command": "gitSimpleCompare.startInteractiveRebase",
        "title": "%cmd.startInteractiveRebase%",
        "category": "Git Simple Compare",
        "icon": "$(list-ordered)"
      },
      {
        "command": "gitSimpleCompare.splitCommits",
        "title": "%cmd.splitCommits%",
        "category": "Git Simple Compare",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "gitSimpleCompare.refreshConflicts",
        "title": "%cmd.refreshConflicts%",
        "category": "Git Simple Compare",
        "icon": "$(refresh)"
      },
      {
        "command": "gitSimpleCompare.takeOurs",
        "title": "%cmd.takeOurs%",
        "category": "Git Simple Compare",
        "icon": "$(arrow-left)"
      },
      {
        "command": "gitSimpleCompare.takeTheirs",
        "title": "%cmd.takeTheirs%",
        "category": "Git Simple Compare",
        "icon": "$(arrow-right)"
      },
      {
        "command": "gitSimpleCompare.markResolved",
        "title": "%cmd.markResolved%",
        "category": "Git Simple Compare",
        "icon": "$(check)"
      },
      {
        "command": "gitSimpleCompare.openMergeEditor",
        "title": "%cmd.openMergeEditor%",
        "category": "Git Simple Compare",
        "icon": "$(git-merge)"
      },
      {
        "command": "gitSimpleCompare.continueOperation",
        "title": "%cmd.continueOperation%",
        "category": "Git Simple Compare",
        "icon": "$(debug-continue)"
      },
      {
        "command": "gitSimpleCompare.abortOperation",
        "title": "%cmd.abortOperation%",
        "category": "Git Simple Compare",
        "icon": "$(circle-slash)"
      },
      { "command": "gitSimpleCompare.rollbackPull", "title": "%cmd.rollbackPull%", "category": "Git Simple Compare", "icon": "$(discard)" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitSimpleCompare",
          "title": "%viewContainer.title%",
          "icon": "$(git-compare)"
        }
      ]
    },
    "views": {
      "gitSimpleCompare": [
        {
          "id": "gitSimpleCompare.changes",
          "name": "%view.changes.name%",
          "type": "webview",
          "icon": "$(git-compare)",
          "contextualTitle": "%viewContainer.title%"
        },
        {
          "id": "gitSimpleCompare.conflicts",
          "name": "%view.conflicts.name%",
          "icon": "$(git-merge)",
          "contextualTitle": "%viewContainer.title%",
          "when": "gitSimpleCompare.hasConflicts || gitSimpleCompare.operationInProgress"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "gitSimpleCompare.conflicts",
        "contents": "%welcome.conflicts%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitSimpleCompare.showGraph",
          "when": "view == gitSimpleCompare.changes",
          "group": "navigation@0"
        },
        {
          "command": "gitSimpleCompare.viewAsTree",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.viewMode == list",
          "group": "navigation@1"
        },
        {
          "command": "gitSimpleCompare.viewAsList",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.viewMode == tree",
          "group": "navigation@1"
        },
        {
          "command": "gitSimpleCompare.changeSortOrder",
          "when": "view == gitSimpleCompare.changes",
          "group": "navigation@2"
        },
        {
          "command": "gitSimpleCompare.checkoutBranch",
          "when": "view == gitSimpleCompare.changes",
          "group": "navigation@3"
        },
        {
          "command": "gitSimpleCompare.refreshChanges",
          "when": "view == gitSimpleCompare.changes",
          "group": "navigation@4"
        },
        {
          "command": "gitSimpleCompare.chooseHunkControlMode",
          "when": "view == gitSimpleCompare.changes",
          "group": "navigation@5"
        },
        {
          "command": "gitSimpleCompare.toggleSection.repos.visible",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.section.repos.visible",
          "group": "2_sections@1"
        },
        {
          "command": "gitSimpleCompare.toggleSection.repos.hidden",
          "when": "view == gitSimpleCompare.changes && !gitSimpleCompare.section.repos.visible",
          "group": "2_sections@1"
        },
        {
          "command": "gitSimpleCompare.toggleSection.changes.visible",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.section.changes.visible",
          "group": "2_sections@2"
        },
        {
          "command": "gitSimpleCompare.toggleSection.changes.hidden",
          "when": "view == gitSimpleCompare.changes && !gitSimpleCompare.section.changes.visible",
          "group": "2_sections@2"
        },
        {
          "command": "gitSimpleCompare.toggleSection.compare.visible",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.section.compare.visible",
          "group": "2_sections@3"
        },
        {
          "command": "gitSimpleCompare.toggleSection.compare.hidden",
          "when": "view == gitSimpleCompare.changes && !gitSimpleCompare.section.compare.visible",
          "group": "2_sections@3"
        },
        {
          "command": "gitSimpleCompare.toggleSection.stashes.visible",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.section.stashes.visible",
          "group": "2_sections@4"
        },
        {
          "command": "gitSimpleCompare.toggleSection.stashes.hidden",
          "when": "view == gitSimpleCompare.changes && !gitSimpleCompare.section.stashes.visible",
          "group": "2_sections@4"
        },
        {
          "command": "gitSimpleCompare.startInteractiveRebase",
          "when": "view == gitSimpleCompare.changes",
          "group": "1_ops@1"
        },
        {
          "command": "gitSimpleCompare.splitCommits",
          "when": "view == gitSimpleCompare.changes",
          "group": "1_ops@2"
        },
        {
          "command": "gitSimpleCompare.continueOperation",
          "when": "view == gitSimpleCompare.conflicts && gitSimpleCompare.operationInProgress",
          "group": "navigation@1"
        },
        {
          "command": "gitSimpleCompare.abortOperation",
          "when": "view == gitSimpleCompare.conflicts && gitSimpleCompare.operationInProgress",
          "group": "navigation@2"
        },
        { "command": "gitSimpleCompare.rollbackPull", "when": "view == gitSimpleCompare.conflicts && gitSimpleCompare.pullRollbackAvailable", "group": "navigation@3" },
        { "command": "gitSimpleCompare.refreshConflicts", "when": "view == gitSimpleCompare.conflicts", "group": "navigation@4" }
      ],
      "view/item/context": [
        {
          "command": "gitSimpleCompare.openMergeEditor",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "inline@0"
        },
        {
          "command": "gitSimpleCompare.takeOurs",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "inline@1"
        },
        {
          "command": "gitSimpleCompare.takeTheirs",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "inline@2"
        },
        {
          "command": "gitSimpleCompare.markResolved",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "inline@3"
        },
        {
          "command": "gitSimpleCompare.takeOurs",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "1_resolve@1"
        },
        {
          "command": "gitSimpleCompare.takeTheirs",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "1_resolve@2"
        },
        {
          "command": "gitSimpleCompare.markResolved",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "1_resolve@3"
        }
      ],
      "editor/title": [
        {
          "command": "gitSimpleCompare.openDiffFileEditor",
          "when": "gitSimpleCompare.activeExtensionDiff",
          "group": "navigation@0"
        },
        {
          "command": "gitSimpleCompare.applyLeftToRight",
          "when": "gitSimpleCompare.activeDiff",
          "group": "navigation@1"
        },
        {
          "command": "gitSimpleCompare.toggleSelectedLineCheckbox",
          "when": "gitSimpleCompare.activeHeadWorkingDiff",
          "group": "navigation@2"
        },
        {
          "command": "gitSimpleCompare.stageSelectedLines",
          "when": "gitSimpleCompare.activeHeadWorkingDiff",
          "group": "navigation@3"
        },
        {
          "command": "gitSimpleCompare.compareActiveFileWithBranch",
          "when": "resourceScheme == file && !gitSimpleCompare.activeDiff",
          "group": "navigation@7"
        }
      ],
      "editor/context": [
        {
          "command": "gitSimpleCompare.toggleSelectedLineCheckbox",
          "when": "gitSimpleCompare.activeHeadWorkingDiff",
          "group": "1_gitSimpleCompare@1"
        },
        {
          "command": "gitSimpleCompare.stageSelectedLines",
          "when": "gitSimpleCompare.activeHeadWorkingDiff",
          "group": "1_gitSimpleCompare@2"
        },
        {
          "command": "gitSimpleCompare.compareActiveFileWithBranch",
          "when": "resourceScheme == file",
          "group": "1_gitSimpleCompare@7"
        }
      ],
      "editor/title/context": [
        {
          "command": "gitSimpleCompare.toggleSelectedLineCheckbox",
          "when": "gitSimpleCompare.activeHeadWorkingDiff",
          "group": "1_gitSimpleCompare@1"
        },
        {
          "command": "gitSimpleCompare.stageSelectedLines",
          "when": "gitSimpleCompare.activeHeadWorkingDiff",
          "group": "1_gitSimpleCompare@2"
        },
        {
          "command": "gitSimpleCompare.compareActiveFileWithBranch",
          "when": "resourceScheme == file",
          "group": "1_gitSimpleCompare@5"
        }
      ],
      "explorer/context": [
        {
          "command": "gitSimpleCompare.compareFileWithBranch",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "3_compare@1"
        }
      ],
      "commandPalette": [
        {
          "command": "gitSimpleCompare.toggleSection.repos.visible",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.repos.hidden",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.changes.visible",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.changes.hidden",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.compare.visible",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.compare.hidden",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.stashes.visible",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.stashes.hidden",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.openChangeDiff",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.changeComparisonRef",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.applyLeftToRight",
          "when": "gitSimpleCompare.activeDiff"
        },
        {
          "command": "gitSimpleCompare.toggleSelectedLineCheckbox",
          "when": "gitSimpleCompare.activeHeadWorkingDiff"
        },
        {
          "command": "gitSimpleCompare.stageSelectedLines",
          "when": "gitSimpleCompare.activeHeadWorkingDiff"
        },
        {
          "command": "gitSimpleCompare.chooseHunkControlMode"
        },
        {
          "command": "gitSimpleCompare.takeOurs",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.takeTheirs",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.markResolved",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.openMergeEditor",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.continueOperation",
          "when": "gitSimpleCompare.operationInProgress"
        },
        {
          "command": "gitSimpleCompare.abortOperation",
          "when": "gitSimpleCompare.operationInProgress"
        }
      ]
    },
    "configuration": {
      "title": "Git Simple Compare",
      "properties": {
        "gitSimpleCompare.diffBase": {
          "type": "string",
          "enum": [
            "twoDot",
            "threeDot"
          ],
          "enumDescriptions": [
            "%config.diffBase.twoDot%",
            "%config.diffBase.threeDot%"
          ],
          "default": "twoDot",
          "description": "%config.diffBase.desc%"
        },
        "gitSimpleCompare.includeRemoteBranches": {
          "type": "boolean",
          "default": true,
          "description": "%config.includeRemote.desc%"
        },
        "gitSimpleCompare.hunkControlMode": {
          "type": "string",
          "enum": [
            "nativeOverlay",
            "command"
          ],
          "enumDescriptions": [
            "%config.hunkControl.nativeOverlay%",
            "%config.hunkControl.command%"
          ],
          "default": "nativeOverlay",
          "description": "%config.hunkControl.desc%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "@vscode/codicons": "^0.0.45",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "ws": "^8.21.0"
  }
}

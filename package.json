        },
        "gitSimpleCompare.aiCommitInstructions": {
          "type": "string",
          "default": "",
          "description": "%config.aiCommitInstructions.desc%"
        },
        "gitSimpleCompare.aiPullRequestInstructions": {
          "type": "string",
          "default": "",
          "description": "%config.aiPullRequestInstructions.desc%"
        },
        "gitSimpleCompare.aiRebaseInstructions": {
          "type": "string",
          "default": "",

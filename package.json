{
  "name": "git-simple-compare",
  "displayName": "Git Simple Compare",
  "description": "%ext.description%",
  "version": "0.1.71036",
  "publisher": "newdlops",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/newdlops/gitsimplecompare.git"
  },
  "bugs": {
    "url": "https://github.com/newdlops/gitsimplecompare/issues"
  },
  "homepage": "https://github.com/newdlops/gitsimplecompare#readme",
  "l10n": "./l10n",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#15384A",
    "theme": "dark"
  },
  "markdown": "github",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "git",
    "diff",
    "compare",
    "branch",
    "merge",
    "rebase",
    "pull-request",
    "ai",
    "codex",
    "claude"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitSimpleCompare.compareBranches",
        "title": "%cmd.compareBranches%",
        "category": "Git Simple Compare",
        "icon": "$(git-compare)"
      },
      {
        "command": "gitSimpleCompare.compareBranchesAdvanced",
        "title": "%cmd.compareBranchesAdvanced%",
        "category": "Git Simple Compare",
        "icon": "$(git-compare)"
      },
      {
        "command": "gitSimpleCompare.openGutterSettings",
        "title": "%cmd.openGutterSettings%",
        "category": "Git Simple Compare",
        "icon": "$(settings-gear)"
      },
      {
        "command": "gitSimpleCompare.selectExplorerComparison",
        "title": "%cmd.selectExplorerComparison%",
        "category": "Git Simple Compare",
        "icon": "$(git-compare)"
      },
      {
        "command": "gitSimpleCompare.compareLocalWithRemote",
        "title": "%cmd.compareLocalWithRemote%",
        "category": "Git Simple Compare",
        "icon": "$(cloud)"
      },
      {
        "command": "gitSimpleCompare.comparePullRequest",
        "title": "%cmd.comparePullRequest%",
        "category": "Git Simple Compare",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "gitSimpleCompare.showExplorerComparison",
        "title": "%cmd.showExplorerComparison.tooltip%",
        "shortTitle": "%cmd.showExplorerComparison%",
        "category": "Git Simple Compare",
        "icon": "$(eye)"
      },
      {
        "command": "gitSimpleCompare.hideExplorerComparison",
        "title": "%cmd.hideExplorerComparison.tooltip%",
        "shortTitle": "%cmd.hideExplorerComparison%",
        "category": "Git Simple Compare",
        "icon": "$(eye-closed)"
      },
      {
        "command": "gitSimpleCompare.refreshExplorerComparison",
        "title": "%cmd.refreshExplorerComparison%",
        "category": "Git Simple Compare",
        "icon": "$(refresh)"
      },
      {
        "command": "gitSimpleCompare.clearExplorerComparison",
        "title": "%cmd.clearExplorerComparison.tooltip%",
        "shortTitle": "%cmd.clearExplorerComparison%",
        "category": "Git Simple Compare",
        "icon": "$(clear-all)"
      },
      {
        "command": "gitSimpleCompare.swapBranchComparison",
        "title": "%cmd.swapBranchComparison.tooltip%",
        "shortTitle": "%cmd.swapBranchComparison%",
        "category": "Git Simple Compare",
        "icon": "$(arrow-swap)",
        "enablement": "gitSimpleCompare.explorerComparison.enabled && gitSimpleCompare.explorerComparison.canSwap"
      },
      {
        "command": "gitSimpleCompare.openComparisonDiff",
        "title": "%cmd.openComparisonDiff%",
        "category": "Git Simple Compare",
        "icon": "$(diff)"
      },
      {
        "command": "gitSimpleCompare.openComparisonFile",
        "title": "%cmd.openComparisonFile%",
        "category": "Git Simple Compare",
        "icon": "$(go-to-file)"
      },
      {
        "command": "gitSimpleCompare.checkoutBranch",
        "title": "%cmd.checkoutBranch.tooltip%",
        "shortTitle": "%cmd.checkoutBranch%",
        "category": "Git Simple Compare",
        "icon": "$(git-branch)"
      },
      {
        "command": "gitSimpleCompare.branchSquashMerge",
        "title": "%cmd.branchSquashMerge.tooltip%",
        "shortTitle": "%cmd.branchSquashMerge%",
        "category": "Git Simple Compare",
        "icon": "$(git-merge)"
      },
      {
        "command": "gitSimpleCompare.branchRebaseMerge",
        "title": "%cmd.branchRebaseMerge.tooltip%",
        "shortTitle": "%cmd.branchRebaseMerge%",
        "category": "Git Simple Compare",
        "icon": "$(repo-forked)"
      },
      {
        "command": "gitSimpleCompare.undoBranchOperation",
        "title": "%cmd.undoBranchOperation.tooltip%",
        "shortTitle": "%cmd.undoBranchOperation%",
        "category": "Git Simple Compare",
        "icon": "$(discard)"
      },
      {
        "command": "gitSimpleCompare.cleanupPrOperationWorktrees",
        "title": "%cmd.cleanupPrOperationWorktrees%",
        "category": "Git Simple Compare",
        "icon": "$(trash)"
      },
      {
        "command": "gitSimpleCompare.compareFileWithBranch",
        "title": "%cmd.compareFileWithBranch%",
        "category": "Git Simple Compare",
        "icon": "$(git-compare)"
      },
      {
        "command": "gitSimpleCompare.compareActiveFileWithBranch",
        "title": "%cmd.compareActiveFileWithBranch.tooltip%",
        "shortTitle": "%cmd.compareActiveFileWithBranch%",
        "category": "Git Simple Compare",
        "icon": "$(git-compare)"
      },
      {
        "command": "gitSimpleCompare.refreshChanges",
        "title": "%cmd.refreshChanges.tooltip%",
        "shortTitle": "%cmd.refreshChanges%",
        "category": "Git Simple Compare",
        "icon": "$(refresh)"
      },
      {
        "command": "gitSimpleCompare.generateCommitMessage",
        "title": "%cmd.generateCommitMessage%",
        "category": "Git Simple Compare",
        "icon": "$(sparkle)"
      },
      {
        "command": "gitSimpleCompare.configureAiCli",
        "title": "%cmd.configureAiCli.tooltip%",
        "shortTitle": "%cmd.configureAiCli%",
        "category": "Git Simple Compare",
        "icon": "$(settings-gear)"
      },
      {
        "command": "gitSimpleCompare.configureUserProfile",
        "title": "%cmd.configureUserProfile.tooltip%",
        "shortTitle": "%cmd.configureUserProfile%",
        "category": "Git Simple Compare",
        "icon": "$(account)"
      },
      {
        "command": "gitSimpleCompare.configureRemoteBranch",
        "title": "%cmd.configureRemoteBranch.tooltip%",
        "shortTitle": "%cmd.configureRemoteBranch%",
        "category": "Git Simple Compare",
        "icon": "$(repo-push)"
      },
      {
        "command": "gitSimpleCompare.setGitHubWebCookie",
        "title": "%cmd.setGitHubWebCookie%",
        "category": "Git Simple Compare",
        "icon": "$(key)"
      },
      {
        "command": "gitSimpleCompare.clearGitHubWebCookie",
        "title": "%cmd.clearGitHubWebCookie%",
        "category": "Git Simple Compare",
        "icon": "$(trash)"
      },
      {
        "command": "gitSimpleCompare.toggleBlameDecorator",
        "title": "%cmd.toggleBlameDecorator%",
        "category": "Git Simple Compare",
        "icon": "$(git-commit)"
      },
      {
        "command": "gitSimpleCompare.toggleBlameDecorator.checked",
        "title": "%cmd.blameDecorator.checked.tooltip%",
        "shortTitle": "%cmd.blameDecorator.checked%",
        "category": "Git Simple Compare",
        "icon": "$(git-commit)"
      },
      {
        "command": "gitSimpleCompare.toggleBlameDecorator.unchecked",
        "title": "%cmd.blameDecorator.tooltip%",
        "shortTitle": "%cmd.blameDecorator%",
        "category": "Git Simple Compare",
        "icon": "$(git-commit)"
      },
      {
        "command": "gitSimpleCompare.toggleBlameLineVisible",
        "title": "%cmd.toggleBlameLineVisible%",
        "category": "Git Simple Compare",
        "icon": "$(list-ordered)"
      },
      {
        "command": "gitSimpleCompare.toggleBlameLineVisible.checked",
        "title": "%cmd.blameLines.checked.tooltip%",
        "shortTitle": "%cmd.blameLines.checked%",
        "category": "Git Simple Compare",
        "icon": "$(list-ordered)"
      },
      {
        "command": "gitSimpleCompare.toggleBlameLineVisible.unchecked",
        "title": "%cmd.blameLines.tooltip%",
        "shortTitle": "%cmd.blameLines%",
        "category": "Git Simple Compare",
        "icon": "$(list-ordered)"
      },
      {
        "command": "gitSimpleCompare.loginAiCli",
        "title": "%cmd.loginAiCli%",
        "category": "Git Simple Compare",
        "icon": "$(account)"
      },
      {
        "command": "gitSimpleCompare.openChangeDiff",
        "title": "%cmd.openChangeDiff%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.changeComparisonRef",
        "title": "%cmd.changeComparisonRef%",
        "category": "Git Simple Compare",
        "icon": "$(edit)"
      },
      {
        "command": "gitSimpleCompare.viewAsTree",
        "title": "%cmd.viewAsTree.tooltip%",
        "shortTitle": "%cmd.viewAsTree%",
        "category": "Git Simple Compare",
        "icon": "$(list-tree)"
      },
      {
        "command": "gitSimpleCompare.viewAsList",
        "title": "%cmd.viewAsList.tooltip%",
        "shortTitle": "%cmd.viewAsList%",
        "category": "Git Simple Compare",
        "icon": "$(list-flat)"
      },
      {
        "command": "gitSimpleCompare.changeSortOrder",
        "title": "%cmd.changeSortOrder.tooltip%",
        "shortTitle": "%cmd.changeSortOrder%",
        "category": "Git Simple Compare",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "gitSimpleCompare.toggleSection.repos.visible",
        "title": "%cmd.section.repos.checked.tooltip%",
        "shortTitle": "%cmd.section.repos.checked%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.repos.hidden",
        "title": "%cmd.section.repos.tooltip%",
        "shortTitle": "%cmd.section.repos%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.changes.visible",
        "title": "%cmd.section.changes.checked.tooltip%",
        "shortTitle": "%cmd.section.changes.checked%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.changes.hidden",
        "title": "%cmd.section.changes.tooltip%",
        "shortTitle": "%cmd.section.changes%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.history.visible",
        "title": "%cmd.section.history.checked.tooltip%",
        "shortTitle": "%cmd.section.history.checked%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.history.hidden",
        "title": "%cmd.section.history.tooltip%",
        "shortTitle": "%cmd.section.history%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.compare.visible",
        "title": "%cmd.section.compare.checked.tooltip%",
        "shortTitle": "%cmd.section.compare.checked%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.compare.hidden",
        "title": "%cmd.section.compare.tooltip%",
        "shortTitle": "%cmd.section.compare%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.stashes.visible",
        "title": "%cmd.section.stashes.checked.tooltip%",
        "shortTitle": "%cmd.section.stashes.checked%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.stashes.hidden",
        "title": "%cmd.section.stashes.tooltip%",
        "shortTitle": "%cmd.section.stashes%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.worktrees.visible",
        "title": "%cmd.section.worktrees.checked.tooltip%",
        "shortTitle": "%cmd.section.worktrees.checked%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.toggleSection.worktrees.hidden",
        "title": "%cmd.section.worktrees.tooltip%",
        "shortTitle": "%cmd.section.worktrees%",
        "category": "Git Simple Compare"
      },
      {
        "command": "gitSimpleCompare.applyLeftToRight",
        "title": "%cmd.applyLeftToRight.tooltip%",
        "shortTitle": "%cmd.applyLeftToRight%",
        "category": "Git Simple Compare",
        "icon": "$(arrow-right)"
      },
      {
        "command": "gitSimpleCompare.openDiffFileEditor",
        "title": "%cmd.openDiffFileEditor.tooltip%",
        "shortTitle": "%cmd.openDiffFileEditor%",
        "category": "Git Simple Compare",
        "icon": "$(go-to-file)",
        "enablement": "gitSimpleCompare.activeExtensionDiff"
      },
      {
        "command": "gitSimpleCompare.stageSelectedLines",
        "title": "%cmd.stageSelectedLines.tooltip%",
        "shortTitle": "%cmd.stageSelectedLines%",
        "category": "Git Simple Compare",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "gitSimpleCompare.toggleSelectedLineCheckbox",
        "title": "%cmd.toggleSelectedLineCheckbox.tooltip%",
        "shortTitle": "%cmd.toggleSelectedLineCheckbox%",
        "category": "Git Simple Compare",
        "icon": "$(checklist)"
      },
      {
        "command": "gitSimpleCompare.chooseHunkControlMode",
        "title": "%cmd.chooseHunkControlMode%",
        "category": "Git Simple Compare",
        "icon": "$(settings-gear)"
      },
      {
        "command": "gitSimpleCompare.showGraph",
        "title": "%cmd.showGraph.tooltip%",
        "shortTitle": "%cmd.showGraph%",
        "category": "Git Simple Compare",
        "icon": "$(graph)"
      },
      {
        "command": "gitSimpleCompare.splitCommits",
        "title": "%cmd.splitCommits.tooltip%",
        "shortTitle": "%cmd.splitCommits%",
        "category": "Git Simple Compare",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "gitSimpleCompare.refreshConflicts",
        "title": "%cmd.refreshConflicts.tooltip%",
        "shortTitle": "%cmd.refreshConflicts%",
        "category": "Git Simple Compare",
        "icon": "$(refresh)"
      },
      { "command": "gitSimpleCompare.takeCurrent", "title": "%cmd.takeCurrent.tooltip%", "shortTitle": "%cmd.takeCurrent%", "category": "Git Simple Compare", "icon": "$(arrow-left)" },
      { "command": "gitSimpleCompare.takeIncoming", "title": "%cmd.takeIncoming.tooltip%", "shortTitle": "%cmd.takeIncoming%", "category": "Git Simple Compare", "icon": "$(arrow-right)" },
      { "command": "gitSimpleCompare.takeBoth", "title": "%cmd.takeBoth.tooltip%", "shortTitle": "%cmd.takeBoth%", "category": "Git Simple Compare", "icon": "$(combine)" },
      {
        "command": "gitSimpleCompare.markResolved",
        "title": "%cmd.markResolved.tooltip%",
        "shortTitle": "%cmd.markResolved%",
        "category": "Git Simple Compare",
        "icon": "$(check)"
      },
      { "command": "gitSimpleCompare.openConflictEditor", "title": "%cmd.openConflictEditor.tooltip%", "shortTitle": "%cmd.openConflictEditor%", "category": "Git Simple Compare", "icon": "$(git-merge)" },
      {
        "command": "gitSimpleCompare.openMergeEditor",
        "title": "%cmd.openMergeEditor%",
        "category": "Git Simple Compare",
        "icon": "$(git-merge)"
      },
      {
        "command": "gitSimpleCompare.continueOperation",
        "title": "%cmd.continueOperation.tooltip%",
        "shortTitle": "%cmd.continueOperation%",
        "category": "Git Simple Compare",
        "icon": "$(debug-continue)"
      },
      {
        "command": "gitSimpleCompare.skipOperation",
        "title": "%cmd.skipOperation.tooltip%",
        "shortTitle": "%cmd.skipOperation%",
        "category": "Git Simple Compare",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "gitSimpleCompare.abortOperation",
        "title": "%cmd.abortOperation.tooltip%",
        "shortTitle": "%cmd.abortOperation%",
        "category": "Git Simple Compare",
        "icon": "$(circle-slash)"
      },
      { "command": "gitSimpleCompare.rollbackPull", "title": "%cmd.rollbackPull.tooltip%", "shortTitle": "%cmd.rollbackPull%", "category": "Git Simple Compare", "icon": "$(discard)" },
      {
        "command": "gitSimpleCompare.refreshWorktrees",
        "title": "%cmd.refreshWorktrees.tooltip%",
        "shortTitle": "%cmd.refreshWorktrees%",
        "category": "Git Simple Compare",
        "icon": "$(refresh)"
      },
      {
        "command": "gitSimpleCompare.createWorktree",
        "title": "%cmd.createWorktree.tooltip%",
        "shortTitle": "%cmd.createWorktree%",
        "category": "Git Simple Compare",
        "icon": "$(plus)"
      },
      {
        "command": "gitSimpleCompare.removeWorktree",
        "title": "%cmd.removeWorktree.tooltip%",
        "shortTitle": "%cmd.removeWorktree%",
        "category": "Git Simple Compare",
        "icon": "$(trash)"
      },
      {
        "command": "gitSimpleCompare.renameWorktree",
        "title": "%cmd.renameWorktree.tooltip%",
        "shortTitle": "%cmd.renameWorktree%",
        "category": "Git Simple Compare",
        "icon": "$(edit)"
      },
      {
        "command": "gitSimpleCompare.openWorktree",
        "title": "%cmd.openWorktree%",
        "category": "Git Simple Compare",
        "icon": "$(go-to-file)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitSimpleCompare",
          "title": "%viewContainer.title%",
          "icon": "resources/activitybar.svg"
        }
      ]
    },
    "views": {
      "gitSimpleCompare": [
        {
          "id": "gitSimpleCompare.changes",
          "name": "%view.changes.name%",
          "type": "webview",
          "icon": "$(git-compare)",
          "contextualTitle": "%viewContainer.title%"
        },
        {
          "id": "gitSimpleCompare.conflicts",
          "name": "%view.conflicts.name%",
          "icon": "$(git-merge)",
          "contextualTitle": "%viewContainer.title%",
          "when": "gitSimpleCompare.hasConflicts || gitSimpleCompare.operationInProgress"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "gitSimpleCompare.conflicts",
        "contents": "%welcome.conflicts%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitSimpleCompare.showExplorerComparison",
          "when": "(view == workbench.explorer.fileView || view == tabManagerExplorer) && (!gitSimpleCompare.explorerComparison.enabled || !gitSimpleCompare.explorerComparison.hasComparison)",
          "group": "navigation@90"
        },
        {
          "command": "gitSimpleCompare.hideExplorerComparison",
          "when": "(view == workbench.explorer.fileView || view == tabManagerExplorer) && gitSimpleCompare.explorerComparison.enabled && gitSimpleCompare.explorerComparison.hasComparison",
          "group": "navigation@90"
        },
        {
          "command": "gitSimpleCompare.swapBranchComparison",
          "when": "(view == workbench.explorer.fileView || view == tabManagerExplorer) && gitSimpleCompare.explorerComparison.enabled && gitSimpleCompare.explorerComparison.canSwap",
          "group": "1_comparison@1"
        },
        {
          "command": "gitSimpleCompare.clearExplorerComparison",
          "when": "(view == workbench.explorer.fileView || view == tabManagerExplorer) && gitSimpleCompare.explorerComparison.hasComparison",
          "group": "1_comparison@2"
        },
        {
          "command": "gitSimpleCompare.showGraph",
          "when": "view == gitSimpleCompare.changes",
          "group": "navigation@0"
        },
        {
          "command": "gitSimpleCompare.viewAsTree",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.viewMode == list",
          "group": "navigation@1"
        },
        {
          "command": "gitSimpleCompare.viewAsList",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.viewMode == tree",
          "group": "navigation@1"
        },
        {
          "command": "gitSimpleCompare.changeSortOrder",
          "when": "view == gitSimpleCompare.changes",
          "group": "navigation@2"
        },
        {
          "command": "gitSimpleCompare.checkoutBranch",
          "when": "view == gitSimpleCompare.changes",
          "group": "navigation@3"
        },
        {
          "command": "gitSimpleCompare.configureUserProfile",
          "when": "view == gitSimpleCompare.changes",
          "group": "1_ops@0"
        },
        {
          "command": "gitSimpleCompare.configureRemoteBranch",
          "when": "view == gitSimpleCompare.changes",
          "group": "1_ops@1"
        },
        {
          "command": "gitSimpleCompare.configureAiCli",
          "when": "view == gitSimpleCompare.changes",
          "group": "1_ops@2"
        },
        {
          "command": "gitSimpleCompare.branchSquashMerge",
          "when": "view == gitSimpleCompare.changes",
          "group": "1_ops@4"
        },
        {
          "command": "gitSimpleCompare.branchRebaseMerge",
          "when": "view == gitSimpleCompare.changes",
          "group": "1_ops@5"
        },
        {
          "command": "gitSimpleCompare.undoBranchOperation",
          "when": "view == gitSimpleCompare.changes",
          "group": "1_ops@6"
        },
        {
          "command": "gitSimpleCompare.refreshChanges",
          "when": "view == gitSimpleCompare.changes",
          "group": "navigation@4"
        },
        {
          "command": "gitSimpleCompare.toggleBlameDecorator.checked",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.blame.decorator.enabled",
          "group": "3_blame@1"
        },
        {
          "command": "gitSimpleCompare.toggleBlameDecorator.unchecked",
          "when": "view == gitSimpleCompare.changes && !gitSimpleCompare.blame.decorator.enabled",
          "group": "3_blame@1"
        },
        {
          "command": "gitSimpleCompare.toggleBlameLineVisible.checked",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.blame.line.visible",
          "group": "3_blame@2"
        },
        {
          "command": "gitSimpleCompare.toggleBlameLineVisible.unchecked",
          "when": "view == gitSimpleCompare.changes && !gitSimpleCompare.blame.line.visible",
          "group": "3_blame@2"
        },
        {
          "command": "gitSimpleCompare.toggleSection.repos.visible",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.section.repos.visible",
          "group": "2_sections@1"
        },
        {
          "command": "gitSimpleCompare.toggleSection.repos.hidden",
          "when": "view == gitSimpleCompare.changes && !gitSimpleCompare.section.repos.visible",
          "group": "2_sections@1"
        },
        {
          "command": "gitSimpleCompare.toggleSection.changes.visible",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.section.changes.visible",
          "group": "2_sections@2"
        },
        {
          "command": "gitSimpleCompare.toggleSection.changes.hidden",
          "when": "view == gitSimpleCompare.changes && !gitSimpleCompare.section.changes.visible",
          "group": "2_sections@2"
        },
        {
          "command": "gitSimpleCompare.toggleSection.compare.visible",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.section.compare.visible",
          "group": "2_sections@4"
        },
        {
          "command": "gitSimpleCompare.toggleSection.compare.hidden",
          "when": "view == gitSimpleCompare.changes && !gitSimpleCompare.section.compare.visible",
          "group": "2_sections@4"
        },
        {
          "command": "gitSimpleCompare.toggleSection.history.visible",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.section.history.visible",
          "group": "2_sections@3"
        },
        {
          "command": "gitSimpleCompare.toggleSection.history.hidden",
          "when": "view == gitSimpleCompare.changes && !gitSimpleCompare.section.history.visible",
          "group": "2_sections@3"
        },
        {
          "command": "gitSimpleCompare.toggleSection.stashes.visible",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.section.stashes.visible",
          "group": "2_sections@5"
        },
        {
          "command": "gitSimpleCompare.toggleSection.stashes.hidden",
          "when": "view == gitSimpleCompare.changes && !gitSimpleCompare.section.stashes.visible",
          "group": "2_sections@5"
        },
        {
          "command": "gitSimpleCompare.toggleSection.worktrees.visible",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.section.worktrees.visible",
          "group": "2_sections@6"
        },
        {
          "command": "gitSimpleCompare.toggleSection.worktrees.hidden",
          "when": "view == gitSimpleCompare.changes && !gitSimpleCompare.section.worktrees.visible",
          "group": "2_sections@6"
        },
        {
          "command": "gitSimpleCompare.splitCommits",
          "when": "view == gitSimpleCompare.changes",
          "group": "1_ops@3"
        },
        {
          "command": "gitSimpleCompare.refreshWorktrees",
          "when": "view == gitSimpleCompare.changes",
          "group": "1_worktrees@0"
        },
        {
          "command": "gitSimpleCompare.createWorktree",
          "when": "view == gitSimpleCompare.changes",
          "group": "1_worktrees@1"
        },
        {
          "command": "gitSimpleCompare.removeWorktree",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.hasLinkedWorktrees",
          "group": "1_worktrees@2"
        },
        {
          "command": "gitSimpleCompare.renameWorktree",
          "when": "view == gitSimpleCompare.changes && gitSimpleCompare.hasLinkedWorktrees",
          "group": "1_worktrees@3"
        },
        {
          "command": "gitSimpleCompare.continueOperation",
          "when": "view == gitSimpleCompare.conflicts && gitSimpleCompare.operationInProgress",
          "group": "navigation@1"
        },
        {
          "command": "gitSimpleCompare.skipOperation",
          "when": "view == gitSimpleCompare.conflicts && gitSimpleCompare.operationIsRebase",
          "group": "navigation@2"
        },
        {
          "command": "gitSimpleCompare.abortOperation",
          "when": "view == gitSimpleCompare.conflicts && gitSimpleCompare.operationInProgress",
          "group": "navigation@3"
        },
        { "command": "gitSimpleCompare.rollbackPull", "when": "view == gitSimpleCompare.conflicts && gitSimpleCompare.pullRollbackAvailable", "group": "navigation@4" },
        { "command": "gitSimpleCompare.refreshConflicts", "when": "view == gitSimpleCompare.conflicts", "group": "navigation@5" }
      ],
      "view/item/context": [
        {
          "command": "gitSimpleCompare.openConflictEditor",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "inline@0"
        },
        {
          "command": "gitSimpleCompare.takeCurrent",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "inline@1"
        },
        {
          "command": "gitSimpleCompare.takeIncoming",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "inline@2"
        },
        {
          "command": "gitSimpleCompare.markResolved",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "inline@3"
        },
        {
          "command": "gitSimpleCompare.takeCurrent",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "1_resolve@1"
        },
        {
          "command": "gitSimpleCompare.takeIncoming",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "1_resolve@2"
        },
        {
          "command": "gitSimpleCompare.takeBoth",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "1_resolve@3"
        },
        {
          "command": "gitSimpleCompare.markResolved",
          "when": "view == gitSimpleCompare.conflicts && viewItem == gitSimpleCompare.conflict",
          "group": "1_resolve@4"
        }
      ],
      "editor/title": [
        {
          "command": "gitSimpleCompare.openDiffFileEditor",
          "when": "gitSimpleCompare.activeExtensionDiff",
          "group": "navigation@0"
        },
        {
          "command": "gitSimpleCompare.applyLeftToRight",
          "when": "gitSimpleCompare.activeDiff",
          "group": "navigation@1"
        },
        {
          "command": "gitSimpleCompare.toggleSelectedLineCheckbox",
          "when": "gitSimpleCompare.activeHeadWorkingDiff",
          "group": "navigation@2"
        },
        {
          "command": "gitSimpleCompare.stageSelectedLines",
          "when": "gitSimpleCompare.activeHeadWorkingDiff",
          "group": "navigation@3"
        },
        {
          "command": "gitSimpleCompare.compareActiveFileWithBranch",
          "when": "resourceScheme == file && !gitSimpleCompare.activeDiff",
          "group": "navigation@7"
        }
      ],
      "editor/context": [
        {
          "command": "gitSimpleCompare.toggleSelectedLineCheckbox",
          "when": "gitSimpleCompare.activeHeadWorkingDiff",
          "group": "1_gitSimpleCompare@1"
        },
        {
          "command": "gitSimpleCompare.stageSelectedLines",
          "when": "gitSimpleCompare.activeHeadWorkingDiff",
          "group": "1_gitSimpleCompare@2"
        },
        {
          "command": "gitSimpleCompare.compareActiveFileWithBranch",
          "when": "resourceScheme == file",
          "group": "1_gitSimpleCompare@7"
        }
      ],
      "editor/title/context": [
        {
          "command": "gitSimpleCompare.toggleSelectedLineCheckbox",
          "when": "gitSimpleCompare.activeHeadWorkingDiff",
          "group": "1_gitSimpleCompare@1"
        },
        {
          "command": "gitSimpleCompare.stageSelectedLines",
          "when": "gitSimpleCompare.activeHeadWorkingDiff",
          "group": "1_gitSimpleCompare@2"
        },
        {
          "command": "gitSimpleCompare.compareActiveFileWithBranch",
          "when": "resourceScheme == file",
          "group": "1_gitSimpleCompare@5"
        }
      ],
      "explorer/context": [
        {
          "command": "gitSimpleCompare.compareFileWithBranch",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "3_compare@1"
        }
      ],
      "commandPalette": [
        {
          "command": "gitSimpleCompare.toggleSection.repos.visible",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.repos.hidden",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.changes.visible",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.changes.hidden",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.history.visible",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.history.hidden",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.compare.visible",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.compare.hidden",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.stashes.visible",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.stashes.hidden",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.worktrees.visible",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleSection.worktrees.hidden",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.openChangeDiff",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.openComparisonDiff",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.openComparisonFile",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.loginAiCli",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.changeComparisonRef",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.applyLeftToRight",
          "when": "gitSimpleCompare.activeDiff"
        },
        {
          "command": "gitSimpleCompare.toggleSelectedLineCheckbox",
          "when": "gitSimpleCompare.activeHeadWorkingDiff"
        },
        {
          "command": "gitSimpleCompare.stageSelectedLines",
          "when": "gitSimpleCompare.activeHeadWorkingDiff"
        },
        {
          "command": "gitSimpleCompare.chooseHunkControlMode"
        },
        {
          "command": "gitSimpleCompare.toggleBlameDecorator.checked",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleBlameDecorator.unchecked",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleBlameLineVisible.checked",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.toggleBlameLineVisible.unchecked",
          "when": "false"
        },
        { "command": "gitSimpleCompare.markResolved", "when": "false" },
        { "command": "gitSimpleCompare.takeCurrent", "when": "false" },
        { "command": "gitSimpleCompare.takeIncoming", "when": "false" },
        { "command": "gitSimpleCompare.takeBoth", "when": "false" },
        { "command": "gitSimpleCompare.openConflictEditor", "when": "false" },
        {
          "command": "gitSimpleCompare.openMergeEditor",
          "when": "false"
        },
        {
          "command": "gitSimpleCompare.continueOperation",
          "when": "gitSimpleCompare.operationInProgress"
        },
        {
          "command": "gitSimpleCompare.skipOperation",
          "when": "gitSimpleCompare.operationIsRebase"
        },
        {
          "command": "gitSimpleCompare.abortOperation",
          "when": "gitSimpleCompare.operationInProgress"
        },
        {
          "command": "gitSimpleCompare.openWorktree",
          "when": "false"
        }
      ]
    },
    "configurationDefaults": {
      "workbench.hover.delay": 0
    },
    "configuration": {
      "title": "Git Simple Compare",
      "properties": {
        "gitSimpleCompare.diffBase": {
          "type": "string",
          "enum": [
            "twoDot",
            "threeDot"
          ],
          "enumDescriptions": [
            "%config.diffBase.twoDot%",
            "%config.diffBase.threeDot%"
          ],
          "default": "twoDot",
          "description": "%config.diffBase.desc%"
        },
        "gitSimpleCompare.includeRemoteBranches": {
          "type": "boolean",
          "default": true,
          "description": "%config.includeRemote.desc%"
        },
        "gitSimpleCompare.hunkControlMode": {
          "type": "string",
          "enum": [
            "nativeOverlay",
            "command"
          ],
          "enumDescriptions": [
            "%config.hunkControl.nativeOverlay%",
            "%config.hunkControl.command%"
          ],
          "default": "nativeOverlay",
          "description": "%config.hunkControl.desc%"
        },
        "gitSimpleCompare.blameLine.show": {
          "type": "boolean",
          "default": false,
          "description": "%config.blameLine.show.desc%"
        },
        "gitSimpleCompare.pullRequestComments.show": {
          "type": "boolean",
          "default": true,
          "description": "%config.pullRequestComments.show.desc%"
        },
        "gitSimpleCompare.aiCliProvider": {
          "type": "string",
          "enum": [
            "auto",
            "claude",
            "codex"
          ],
          "enumDescriptions": [
            "%config.aiCliProvider.auto%",
            "%config.aiCliProvider.claude%",
            "%config.aiCliProvider.codex%"
          ],
          "default": "auto",
          "description": "%config.aiCliProvider.desc%"
        },
        "gitSimpleCompare.aiClaudeCommand": {
          "type": "string",
          "default": "claude",
          "description": "%config.aiClaudeCommand.desc%"
        },
        "gitSimpleCompare.aiClaudeModel": {
          "type": "string",
          "default": "",
          "description": "%config.aiClaudeModel.desc%"
        },
        "gitSimpleCompare.aiClaudeEffort": {
          "type": "string",
          "enum": [
            "",
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ],
          "enumDescriptions": [
            "%config.aiEffort.default%",
            "%config.aiEffort.low%",
            "%config.aiEffort.medium%",
            "%config.aiEffort.high%",
            "%config.aiEffort.xhigh%",
            "%config.aiEffort.max%"
          ],
          "default": "",
          "description": "%config.aiClaudeEffort.desc%"
        },
        "gitSimpleCompare.aiClaudeSystemPrompt": {
          "type": "string",
          "default": "",
          "description": "%config.aiClaudeSystemPrompt.desc%"
        },
        "gitSimpleCompare.aiClaudeLoginMode": {
          "type": "string",
          "enum": [
            "claudeai",
            "console",
            "sso",
            "setup-token"
          ],
          "enumDescriptions": [
            "%config.aiClaudeLoginMode.claudeai%",
            "%config.aiClaudeLoginMode.console%",
            "%config.aiClaudeLoginMode.sso%",
            "%config.aiClaudeLoginMode.setupToken%"
          ],
          "default": "claudeai",
          "description": "%config.aiClaudeLoginMode.desc%"
        },
        "gitSimpleCompare.aiCodexCommand": {
          "type": "string",
          "default": "codex",
          "description": "%config.aiCodexCommand.desc%"
        },
        "gitSimpleCompare.aiCodexModel": {
          "type": "string",
          "default": "",
          "description": "%config.aiCodexModel.desc%"
        },
        "gitSimpleCompare.aiCodexReasoningEffort": {
          "type": "string",
          "enum": [
            "",
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ],
          "enumDescriptions": [
            "%config.aiEffort.default%",
            "%config.aiEffort.low%",
            "%config.aiEffort.medium%",
            "%config.aiEffort.high%",
            "%config.aiEffort.xhigh%",
            "%config.aiEffort.max%"
          ],
          "default": "",
          "description": "%config.aiCodexReasoningEffort.desc%"
        },
        "gitSimpleCompare.aiCodexProfile": {
          "type": "string",
          "default": "",
          "description": "%config.aiCodexProfile.desc%"
        },
        "gitSimpleCompare.aiCodexLoginMode": {
          "type": "string",
          "enum": [
            "browser",
            "device",
            "api-key",
            "access-token"
          ],
          "enumDescriptions": [
            "%config.aiCodexLoginMode.browser%",
            "%config.aiCodexLoginMode.device%",

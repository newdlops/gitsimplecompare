        "gitSimpleCompare.aiResponseLanguage": {
          "type": "string",
          "default": "English",
          "description": "%config.aiResponseLanguage.desc%"
        },
        "gitSimpleCompare.aiCommonInstructions": {
          "type": "string",
          "default": "",

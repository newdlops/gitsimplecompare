  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "pretest": "esbuild test/commitHookFailure.test.ts test/commitHookService.test.ts test/extensionRefreshPolicy.test.ts --bundle --platform=node --format=cjs --outdir=out-test",
    "test": "node --test out-test/commitHookFailure.test.js out-test/commitHookService.test.js out-test/extensionRefreshPolicy.test.js",
    "lint": "eslint src"
  },
